VER TODOS LOS LIKES DE UN USUARIOS

SELECT 
    p.id_publicacion,
    p.contenido_texto,
    p.fecha_publicacion
FROM likes l
JOIN publicaciones p ON l.id_publicacion = p.id_publicacion
WHERE l.id_usuario = 1;

CONTAR NUMERO DE LIKES

SELECT 
    COUNT(*) AS total_likes
FROM likes
WHERE id_publicacion = 1;
