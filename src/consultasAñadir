VER TODOS LOS COMENTARIOS DE UN USUARIO

SELECT 
    c.id_comentario,
    c.texto,
    p.id_publicacion,
    p.contenido_texto
FROM comentarios c
JOIN publicaciones p ON c.id_publicacion = p.id_publicacion
WHERE c.id_usuario = 1

CONTAR NUMERO DE COMENTARIOS

SELECT 
    COUNT(*) AS total_comentarios
FROM comentarios
WHERE id_publicacion = 1;

